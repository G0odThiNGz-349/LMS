   "source": [
    "pending = spark.sql(\"\"\"\n",
    "    SELECT file_path FROM control.pending_files \n",
    "    WHERE status = 'pending'\n",
    "\"\"\").collect()\n",
    "\n",
    "pending_list = [row.file_path for row in pending]\n",
    "\n",
    "mssparkutils.notebook.exit(str(pending_list))"
   ]
  }
